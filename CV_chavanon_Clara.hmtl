<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clara Chavanon — Aerospace & Space Engineering</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#f7f9ff;color:#1a2540;font-family:'Outfit',sans-serif;font-size:13.5px;line-height:1.65;}
.page{max-width:820px;margin:0 auto;padding:52px 40px 72px;background:#f7f9ff;}
.header{display:grid;grid-template-columns:1fr auto;align-items:end;gap:32px;margin-bottom:44px;padding-bottom:36px;border-bottom:1px solid #dce6f5;}
h1{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:52px;letter-spacing:-0.01em;line-height:1;color:#0f1d3a;margin-bottom:8px;}
h1 em{font-style:italic;color:#2b6cb0;}
.role{font-size:12.5px;font-weight:400;color:#5a7aa8;letter-spacing:0.04em;margin-bottom:22px;text-transform:uppercase;}
.contacts{display:flex;flex-wrap:wrap;gap:8px;}
.contact-pill{display:inline-flex;align-items:center;gap:6px;padding:6px 13px;border-radius:100px;border:1px solid #c9daf4;background:white;color:#2563a8;font-size:12.5px;text-decoration:none;font-weight:400;transition:background 0.15s,border-color 0.15s;}
.contact-pill:hover{background:#ebf2fd;border-color:#93b8e8;}
.contact-pill svg{width:13px;height:13px;flex-shrink:0;stroke:#5a90d0;}
.badge{background:white;border:1px solid #c9daf4;border-radius:10px;padding:14px 18px;text-align:center;}
.badge-label{font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#7ba4cc;margin-bottom:4px;}
.badge-value{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;color:#1a4a8a;line-height:1.3;}
.body{display:grid;grid-template-columns:1fr 230px;gap:44px;align-items:start;}
.section{margin-bottom:34px;}
.section-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.14em;color:#93b4d4;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.section-label::after{content:'';flex:1;height:1px;background:#dce6f5;}
.entry{margin-bottom:14px;padding:15px 18px;background:white;border:1px solid #e4edf8;border-radius:10px;transition:border-color 0.15s;}
.entry:hover{border-color:#b8d0f0;}
.entry-top{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:3px;}
.entry-title{font-family:'Outfit',sans-serif;font-weight:500;font-size:14px;color:#0f1d3a;line-height:1.3;}
.entry-date{font-size:11.5px;color:#93b4d4;white-space:nowrap;flex-shrink:0;padding-top:2px;}
.entry-org{font-size:12.5px;color:#4a7fbf;margin-bottom:8px;font-style:italic;}
.entry-body{font-size:12.5px;color:#4a5e7a;line-height:1.7;}
.entry-body li{list-style:none;padding-left:13px;position:relative;margin-bottom:3px;}
.entry-body li::before{content:'–';position:absolute;left:0;color:#93b4d4;}
.sidebar-section{margin-bottom:26px;}
.sidebar-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:#93b4d4;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #e4edf8;}
.tags{display:flex;flex-wrap:wrap;gap:6px;}
.tag{font-size:11.5px;padding:4px 10px;border-radius:100px;border:1px solid #c9daf4;background:white;color:#185FA5;font-weight:400;}
.tag-soft{font-size:11.5px;padding:4px 10px;border-radius:100px;background:#edf4fd;border:1px solid #edf4fd;color:#2563a8;}
.lang-item{margin-bottom:10px;}
.lang-top{display:flex;justify-content:space-between;margin-bottom:4px;font-size:12.5px;}
.lang-name{color:#2a3f60;font-weight:400;}
.lang-lvl{color:#93b4d4;font-size:11px;}
.lang-track{height:2px;background:#e4edf8;border-radius:2px;overflow:hidden;}
.lang-fill{height:100%;background:#4a90d4;border-radius:2px;}
.cert{font-size:12.5px;color:#4a5e7a;padding:6px 0;border-bottom:1px solid #f0f4fb;display:flex;align-items:center;gap:8px;}
.cert:last-child{border-bottom:none;}
.cert-dot{width:4px;height:4px;border-radius:50%;background:#93b4d4;flex-shrink:0;}
.interest-row{display:flex;flex-wrap:wrap;gap:5px;}
.interest{font-size:11.5px;padding:4px 10px;border-radius:100px;background:#edf4fd;color:#3a6fa8;border:1px solid #d4e5f7;}
.footer{margin-top:48px;padding-top:20px;border-top:1px solid #dce6f5;text-align:center;font-size:11px;color:#b0c4db;letter-spacing:0.06em;}
@media(max-width:640px){.body{grid-template-columns:1fr;}.header{grid-template-columns:1fr;}h1{font-size:36px;}.page{padding:28px 20px 48px;}}
</style>
</head>
<body>
<div class="page">

<header class="header">
  <div>
    <h1>Clara <em>Chavanon</em></h1>
    <p class="role">MSc Aeronautical &amp; Space Engineering &middot; EPF Paris-Cachan &middot; Minor in Design &amp; Structural Analysis</p>
    <div class="contacts">
      <a class="contact-pill" href="mailto:clara.chavanon9@outlook.fr">
        <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,14 22,4"/></svg>
        clara.chavanon9@outlook.fr
      </a>
      <a class="contact-pill" href="https://www.linkedin.com/in/clara-chavanon/" target="_blank" rel="noopener">
        <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        linkedin.com/in/clara-chavanon
      </a>
      <a class="contact-pill" href="#">
        <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Paris &middot; Cachan, France
      </a>
    </div>
  </div>
  <div class="badge">
    <div class="badge-label">Seeking</div>
    <div class="badge-value">6-month internship<br>from Feb 2027</div>
    <div style="font-size:11px;color:#7ba4cc;margin-top:6px;">Aero / Space / Motorsport</div>
  </div>
</header>

<div class="body">
  <div>

    <div class="section">
      <div class="section-label">Education</div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">EPF Graduate School of Engineering</div>
          <div class="entry-date">2022 – 2027</div>
        </div>
        <div class="entry-org">5-year Integrated Master's &middot; Specialisation: Aeronautical &amp; Space Engineering &middot; Minor: Design &amp; Structural Analysis</div>
        <ul class="entry-body">
          <li>2025–2027: Aeronautical &amp; Space specialisation : simulation, embedded systems, fluid mechanics, structures</li>
          <li>2022–2025: General engineering core advanced mathematics, physics, computing</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Lycée Français de Barcelone</div>
          <div class="entry-date">2013 – 2020</div>
        </div>
        <div class="entry-org">French Scientific Baccalaureate with High Honors&middot; Barcelona, Spain</div>
        <ul class="entry-body">
          <li>Specialisations: Mathematics, Physics &amp; Chemistry &middot; Advanced Mathematics option</li>
        </ul>
      </div>
    </div>

    <div class="section">
      <div class="section-label">Experience</div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">R&amp;D Data Engineering Intern</div>
          <div class="entry-date">Jul – Dec 2025</div>
        </div>
        <div class="entry-org">CHU Sainte-Justine &middot; Montréal, Canada</div>
        <ul class="entry-body">
          <li>Built a Python / SQLite application automating patient pre-screening in the Pediatric Intensive Care Unit</li>
          <li>Designed a secure, modular framework adapted to high-stakes operational requirements</li>
          <li>Reduced manual analysis time and data processing latency across medical teams</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Civic Engagement Intern</div>
          <div class="entry-date">Jun – Jul 2024</div>
        </div>
        <div class="entry-org">Emmaüs &middot; Aix-en-Provence, France</div>
        <ul class="entry-body">
          <li>Managed sales operations and customer relations for the solidarity store</li>
          <li>Taught French language sessions to beneficiaries as part of social integration support</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Academic Tutor — Mathematics &amp; Physics</div>
          <div class="entry-date">Sep 2024 – Present</div>
        </div>
        <div class="entry-org">Apprentius / Parkours &middot; France</div>
        <ul class="entry-body">
          <li>Tutoring secondary school students up to final year in mathematics and physics</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Section Leader &amp; Server</div>
          <div class="entry-date">Jun 2023 – Feb 2025</div>
        </div>
        <div class="entry-org">Le Loulou Antony &middot; France</div>
        <ul class="entry-body">
          <li>Managed a team of 4, coordinated service flow and optimised operations under pressure</li>
        </ul>
      </div>
    </div>

    <div class="section">
      <div class="section-label">Projects</div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Linear Actuation System — SAL26 Engineering Project</div>
          <div class="entry-date">Feb – Jun 2026</div>
        </div>
        <div class="entry-org">EPF Paris-Cachan &middot; Systems Engineering Course (4th year)</div>
        <ul class="entry-body">
          <li>Designed a linear actuation system (SAL) for a movable aeronautical surface integrated into a new-type aircraft, operating in long-haul commercial flight environments</li>
          <li>Defined operational requirements, functional architecture (FBS, use-case &amp; context diagrams) and preliminary failure mode analysis (APR)</li>
          <li>Specified two eligible actuation architectures with full energy conversion breakdown; selected optimal ATR through comparative analysis</li>
          <li>Produced organic technical specifications for supplier consultation and detailed product-process definition for internally manufactured interface parts (CATIA V5)</li>
          <li>System interfaces: ARINC 429 bus (angle &amp; force telemetry), 48 V DC power supply up to 10 kW</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Hydraulic Cylinder — MAESTRO Tele-operated Robot</div>
          <div class="entry-date">2024 – 2025</div>
        </div>
        <div class="entry-org">EPF Paris-Cachan &middot; System Design Project</div>
        <ul class="entry-body">
          <li>Modelled hydraulic cylinder geometry in CATIA V5 and ran full system simulation in AMESIM</li>
          <li>Validated actuation performance and dynamic behaviour under operational load cases</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Step Motors &amp; Hybrid Motors — Energy Conversion</div>
          <div class="entry-date">2024 – 2025</div>
        </div>
        <div class="entry-org">EPF Paris-Cachan</div>
        <ul class="entry-body">
          <li>Research and practical work on stepper motors, hybrid motors, permanent-magnet and variable-reluctance machines</li>
          <li>Applied energy conversion theory to motor selection and performance characterisation</li>
        </ul>
      </div>
    </div>

    <div class="section">
      <div class="section-label">Leadership &amp; Associations</div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Vice-President — Apostrophe Association</div>
          <div class="entry-date">2023 – 2025</div>
        </div>
        <div class="entry-org">EPF Paris-Cachan</div>
        <ul class="entry-body">
          <li>Led a 30-member campus media &amp; photography team, overseeing logistics and budget</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Event Organiser — Gala Association</div>
          <div class="entry-date">2023 – 2025</div>
        </div>
        <div class="entry-org">EPF Paris-Cachan</div>
        <ul class="entry-body">
          <li>Managed vendor negotiations and high-budget bookings for 1,000+ attendees</li>
        </ul>
      </div>
      <div class="entry">
        <div class="entry-top">
          <div class="entry-title">Delegate — PALMUN &amp; DIAMED</div>
          <div class="entry-date">2020 – 2021</div>
        </div>
        <div class="entry-org">Palma de Mallorca &amp; Barcelona, Spain</div>
        <ul class="entry-body">
          <li>Represented Ethiopia at a UN General Assembly simulation; elected Africa delegate for amendment proposals</li>
          <li>Collaborated with Union for the Mediterranean on Women's Rights and gender equality discussions</li>
        </ul>
      </div>
    </div>

  </div>

  <aside>
    <div class="sidebar-section">
      <div class="sidebar-label">Simulation &amp; CAD</div>
      <div class="tags">
        <span class="tag">MATLAB</span>
        <span class="tag">Simulink</span>
        <span class="tag">AMESIM</span>
        <span class="tag">CATIA V5</span>
        <span class="tag">Abaqus</span>
      </div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">Programming</div>
      <div class="tags">
        <span class="tag-soft">Python</span>
        <span class="tag-soft">SQLite</span>
        <span class="tag-soft">Java</span>
        <span class="tag-soft">VBA / SQL</span>
        <span class="tag-soft">Arduino</span>
        <span class="tag-soft">HTML / CSS</span>
        <span class="tag-soft">GitHub</span>
      </div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">Languages</div>
      <div class="lang-item">
        <div class="lang-top"><span class="lang-name">French</span><span class="lang-lvl">Native</span></div>
        <div class="lang-track"><div class="lang-fill" style="width:100%"></div></div>
      </div>
      <div class="lang-item">
        <div class="lang-top"><span class="lang-name">Spanish</span><span class="lang-lvl">C2 – Bilingual</span></div>
        <div class="lang-track"><div class="lang-fill" style="width:100%"></div></div>
      </div>
      <div class="lang-item">
        <div class="lang-top"><span class="lang-name">English</span><span class="lang-lvl">C2 – IELTS 7.5</span></div>
        <div class="lang-track"><div class="lang-fill" style="width:97%"></div></div>
      </div>
      <div class="lang-item">
        <div class="lang-top"><span class="lang-name">Catalan</span><span class="lang-lvl">Proficient</span></div>
        <div class="lang-track"><div class="lang-fill" style="width:62%"></div></div>
      </div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">Certifications</div>
      <div class="cert"><div class="cert-dot"></div>IELTS 7.5 (C2)</div>
      <div class="cert"><div class="cert-dot"></div>PADI Advanced Open Water</div>
      <div class="cert"><div class="cert-dot"></div>PSC1 — First Aid</div>
      <div class="cert"><div class="cert-dot"></div>Galop 3 — Equestrian</div>
      <div class="cert"><div class="cert-dot"></div>PIX</div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">Interests</div>
      <div class="interest-row">
        <span class="interest">Formula 1</span>
        <span class="interest">Space</span>
        <span class="interest">Scuba diving</span>
        <span class="interest">Alpine skiing</span>
        <span class="interest">Running</span>
        <span class="interest">Travel</span>
      </div>
    </div>
  </aside>
</div>

<div class="footer">Clara Chavanon &middot; Aerospace &amp; Space Engineering &middot; EPF 2027</div>
</div>
</body>
</html>
